# ========================================
# X Developer App の Client ID
# ========================================
# 取得手順:
#   1. https://developer.x.com → Projects & Apps → Create App
#   2. User authentication settings → OAuth 2.0 を有効化
#      - Type: Native App
#      - Callback URI: http://127.0.0.1:3001/oauth/callback
#      - Website URL: https://x.com (任意)
#   3. Client ID を下記にコピー
X_CLIENT_ID=your_client_id_here

# OAuth 2.0 クライアントシークレット（Confidential Client の場合）
# Keys and tokens ページに表示されたクライアントシークレット（新しい方）を設定
X_CLIENT_SECRET=your_client_secret_here

# ========================================
# 以下は npm run login 実行後に自動設定されます
# ========================================
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=

# Web セッション用 Cookie（Playwright が使用）
X_AUTH_TOKEN=
X_CSRF_TOKEN=
